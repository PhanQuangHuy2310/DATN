# --- SERVER CONFIGURATION ---
SERVER_PORT=8080

# --- DATABASE CONFIGURATION (PostgreSQL / Supabase Postgres) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tim_tro_db
DB_USERNAME=postgres
DB_PASSWORD=your_database_password_here

# --- Spring Security & JWT ---
JWT_SECRET=your_super_secret_jwt_key_should_be_at_least_32_characters_long
JWT_EXPIRATION_MS=86400000

# --- SUPABASE STORAGE CONFIGURATION ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-service-role-key-or-anon-key
SUPABASE_BUCKET=rental-media

# --- MAIL SMTP CONFIGURATION (Gmail/Resend/Brevo) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_email_app_password

# --- PAYMENT SANDBOX (MoMo / ZaloPay) ---
MOMO_PARTNER_CODE=MOMO_PARTNER_CODE_HERE
MOMO_ACCESS_KEY=MOMO_ACCESS_KEY_HERE
MOMO_SECRET_KEY=MOMO_SECRET_KEY_HERE
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
